# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=orus
POSTGRES_PASSWORD=orus_secret
POSTGRES_DB=orus_db
DATABASE_URL=postgresql://orus:orus_secret@localhost:5432/orus_db

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=troque_por_um_segredo_forte_em_producao
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── Meta Ads (por integração, salvo no banco por perfil) ────
# META_APP_ID=
# META_APP_SECRET=

# ─── Google Analytics 4 ──────────────────────────────────────
# GA4_MEASUREMENT_ID=
# GA4_API_SECRET=

# ─── Encryption (para tokens de integração salvos no banco) ──
ENCRYPTION_KEY=32_chars_random_key_here_change_me
